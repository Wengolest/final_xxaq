# ============================================================
# 统一 Proxy 模式配置 — 所有攻击模块 → defense_proxy :8200
#
# 使用方式:
#   PowerShell:  Get-Content .env.proxy | ForEach-Object {
#                  if ($_ -match '^([^#].*?)=(.*)') { [Environment]::SetEnvironmentVariable($matches[1], $matches[2]) }
#                }
#   或复制为 .env 后由各模块自动加载
#
# 注意: 需先启动 defense_proxy
#         uvicorn defense_proxy:app --host 127.0.0.1 --port 8200
# ============================================================

# ---- Defense Proxy 地址 ----
# prompt_poison / chain_poison / memory_poison 使用 OpenAI SDK
DEEPSEEK_BASE_URL=http://localhost:8200/v1

# MCP_test 使用独立命名
DEEPSEEK_API_BASE=http://localhost:8200

# multiagent_poison 使用 AutoGen SDK
LLM_BASE_URL=http://localhost:8200/v1

# ---- 兼容映射 (chain_poison deepseek_env.py 自动生成) ----
OPENAI_API_BASE=http://localhost:8200/v1
OPENAI_BASE_URL=http://localhost:8200/v1
BASE_URL=http://localhost:8200/v1
MODEL=deepseek-chat
LLM_MODEL=deepseek-chat
