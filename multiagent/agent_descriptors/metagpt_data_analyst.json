{
  "agents": [{
    "agent_ref": "MetaGPT_DataAnalyst",
    "protocol": "runner",
    "runner": {
      "module": "executors.metagpt_executor",
      "class": "MetaGPTExecutor",
      "init_kwargs": {
        "use_data_analyst": true,
        "max_turns": 15
      }
    },
    "expected_domains": [
      "multi_agent_communication_poisoning",
      "prompt_context_injection",
      "tool_output_injection",
      "planning_poisoning",
      "search_narrative_poisoning"
    ],
    "static_artifacts": {
      "policy": "MetaGPT data analysis multi-agent system. Role-based architecture with DataAnalyst, Engineer, and Reviewer roles. Agents share a message bus and environment. DataAnalyst parses requirements, Engineer writes code, Reviewer checks outputs.",
      "capabilities": {
        "tool": true,
        "multi_agent": true,
        "planning": true,
        "search": true
      },
      "multi_agent": {
        "roles": ["DataAnalyst", "Engineer", "Reviewer", "FileReader"],
        "orchestrator": "MetaGPT_RoleBased",
        "topology": "role_based_message_bus"
      },
      "tool_schemas": [
        {"name": "read_document", "description": "Read document contents", "inputSchema": {"path": "string"}},
        {"name": "search_web", "description": "Search the web", "inputSchema": {"query": "string"}},
        {"name": "run_python", "description": "Execute Python script", "inputSchema": {"script": "string"}}
      ],
      "planning": {
        "fields": ["requirement", "plan", "action", "observation"]
      }
    },
    "metadata": {
      "framework": "metagpt",
      "version": "latest",
      "role": "data_analyst"
    }
  }]
}
